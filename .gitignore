# pyenv
#   For a library or app, you might want to share your .python-version.
#   Development personal preference:
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different models/operating systems,
#   writing entry to pipenv may cause dependency mismatch.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be gitignored or not, depending on preference.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be gitignored or not, depending on preference
.pdm.toml
.pdm-plugins/
__pypackages__/

